@model VerifyOtpViewModel

@{
    Layout = "_AuthSplitLayout";
    ViewBag.Title = "Verify OTP";
}

<div class="space-y-2">
    <h2 class="text-on-surface font-display-date text-3xl tracking-tight">
        Verify Gmail
    </h2>

    <p class="text-on-surface-variant font-body-md">
        Enter the 6-digit OTP sent to your Gmail to activate your account.
    </p>
</div>

<form asp-controller="Auth" asp-action="VerifyOtp" method="post" class="space-y-6">
    @Html.AntiForgeryToken()

    <input asp-for="Email" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-error text-sm"></div>

    <div class="space-y-1.5">
        <label asp-for="Otp" class="font-label-caps text-on-surface-variant uppercase">
            OTP Code
        </label>

        <input asp-for="Otp"
               maxlength="6"
               class="w-full h-12 bg-white border border-outline-variant rounded-lg px-4 text-on-surface placeholder:text-outline focus:outline-none focus:border-primary-container focus:ring-1 focus:ring-primary-container transition-all font-body-md tracking-[10px] text-center"
               placeholder="000000" />

        <span asp-validation-for="Otp" class="text-error text-sm"></span>
    </div>

    <button class="w-full h-12 bg-primary-container hover:bg-opacity-90 active:opacity-80 text-white font-headline-sm rounded-lg flex items-center justify-center gap-2 transition-all cursor-pointer shadow-lg shadow-primary-container/10"
            type="submit">
        <span>Verify OTP</span>
        <span class="material-symbols-outlined text-[18px]">verified</span>
    </button>
</form>

<div class="pt-6 border-t border-outline-variant flex flex-col items-center gap-4">
    <a asp-controller="Auth"
       asp-action="Login"
       class="flex items-center gap-2 text-primary hover:text-surface-tint font-body-md transition-colors group">
        <span class="material-symbols-outlined text-[18px] group-hover:-translate-x-1 transition-transform">arrow_back</span>
        Back to login
    </a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
