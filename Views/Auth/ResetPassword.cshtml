@model ResetPasswordViewModel

@{
    Layout = "_AuthSplitLayout";
    ViewBag.Title = "Reset Password";
}

<div class="space-y-2">
    <h2 class="text-on-surface font-display-date text-3xl tracking-tight">
        Reset Password
    </h2>

    <p class="text-on-surface-variant font-body-md">
        Create a new password for your ChronoPlan account.
    </p>
</div>

<form asp-controller="Auth" asp-action="ResetPassword" method="post" class="space-y-6">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-error text-sm"></div>

    <div class="space-y-1.5">
        <label asp-for="NewPassword" class="font-label-caps text-on-surface-variant uppercase">
            New Password
        </label>

        <input asp-for="NewPassword"
               type="password"
               class="w-full h-12 bg-white border border-outline-variant rounded-lg px-4 text-on-surface placeholder:text-outline focus:outline-none focus:border-primary-container focus:ring-1 focus:ring-primary-container transition-all font-body-md"
               placeholder="••••••••" />

        <span asp-validation-for="NewPassword" class="text-error text-sm"></span>
    </div>

    <div class="space-y-1.5">
        <label asp-for="ConfirmPassword" class="font-label-caps text-on-surface-variant uppercase">
            Confirm Password
        </label>

        <input asp-for="ConfirmPassword"
               type="password"
               class="w-full h-12 bg-white border border-outline-variant rounded-lg px-4 text-on-surface placeholder:text-outline focus:outline-none focus:border-primary-container focus:ring-1 focus:ring-primary-container transition-all font-body-md"
               placeholder="••••••••" />

        <span asp-validation-for="ConfirmPassword" class="text-error text-sm"></span>
    </div>

    <button class="w-full h-12 bg-primary-container hover:bg-opacity-90 active:opacity-80 text-white font-headline-sm rounded-lg flex items-center justify-center gap-2 transition-all cursor-pointer shadow-lg shadow-primary-container/10"
            type="submit">
        <span>Reset Password</span>
        <span class="material-symbols-outlined text-[18px]">lock_reset</span>
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
