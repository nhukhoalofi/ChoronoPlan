@model ForgotPasswordViewModel

@{
    Layout = "_AuthSplitLayout";
    ViewBag.Title = "Forgot Password";
}

<div class="space-y-2">
    <h2 class="text-on-surface font-display-date text-3xl tracking-tight">
        Forgot Password?
    </h2>

    <p class="text-on-surface-variant font-body-md">
        Enter the Gmail associated with your account and we'll send a 6-digit OTP to reset your access.
    </p>
</div>

<form asp-controller="Auth" asp-action="ForgotPassword" method="post" class="space-y-6">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-error text-sm"></div>

    <div class="space-y-1.5">
        <label asp-for="Email" class="font-label-caps text-on-surface-variant uppercase">
            Gmail
        </label>

        <div class="relative group">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-outline group-focus-within:text-primary-container transition-colors">
                <span class="material-symbols-outlined text-[20px]">mail</span>
            </div>

            <input asp-for="Email"
                   class="w-full h-12 bg-white border border-outline-variant rounded-lg pl-11 pr-4 text-on-surface placeholder:text-outline focus:outline-none focus:border-primary-container focus:ring-1 focus:ring-primary-container transition-all font-body-md"
                   placeholder="name@gmail.com"
                   type="email" />
        </div>

        <span asp-validation-for="Email" class="text-error text-sm"></span>
    </div>

    <button class="w-full h-12 bg-primary-container hover:bg-opacity-90 active:opacity-80 text-white font-headline-sm rounded-lg flex items-center justify-center gap-2 transition-all cursor-pointer shadow-lg shadow-primary-container/10"
            type="submit">
        <span>Send OTP</span>
        <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
    </button>
</form>

<div class="pt-6 border-t border-outline-variant flex flex-col items-center gap-4">
    <a asp-controller="Auth"
       asp-action="Login"
       class="flex items-center gap-2 text-primary hover:text-surface-tint font-body-md transition-colors group">
        <span class="material-symbols-outlined text-[18px] group-hover:-translate-x-1 transition-transform">arrow_back</span>
        Back to login
    </a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
