<!DOCTYPE html>
<html lang="en">
<head>
    <title>@ViewBag.Title - ChronoPlan</title>
    <partial name="_ThemeHead" />
</head>

<body class="bg-background text-on-background font-body-md antialiased selection:bg-primary-container selection:text-white">
    <div class="min-h-screen flex flex-col md:flex-row overflow-hidden bg-surface-dim">
        <aside class="hidden lg:flex w-1/2 relative overflow-hidden bg-[#f8fafc] border-r border-[#e5e7eb]">
            <div class="absolute inset-0 bg-gradient-to-br from-[#eff6ff] via-transparent to-transparent z-10"></div>

            <div class="absolute inset-0 opacity-30 bg-[radial-gradient(circle_at_center,#1a73e8_0%,transparent_45%)]"></div>

            <div class="relative z-20 flex flex-col justify-between p-12 h-full">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-primary-container rounded-lg flex items-center justify-center">
                        <span class="material-symbols-outlined text-white">schedule</span>
                    </div>
                    <span class="font-inter text-xl font-bold text-[#111827] tracking-tight">ChronoPlan</span>
                </div>

                <div class="max-w-md">
                    <h1 class="font-display-date text-[#111827] text-4xl mb-4 leading-tight">
                        Master your time, <br />define your future.
                    </h1>
                    <p class="text-on-surface-variant text-lg">
                        Secure your workspace with our productivity calendar system.
                    </p>
                </div>

                <div class="text-sm text-outline">
                    © 2026 ChronoPlan Productivity Systems.
                </div>
            </div>
        </aside>

        <main class="flex-1 flex flex-col items-center justify-center p-6 md:p-12 bg-surface-dim">
            <div class="w-full max-w-[400px] space-y-8">
                <div class="lg:hidden flex flex-col items-center text-center mb-8">
                    <div class="w-12 h-12 bg-primary-container rounded-xl flex items-center justify-center mb-4">
                        <span class="material-symbols-outlined text-white text-3xl">lock_reset</span>
                    </div>
                    <h2 class="font-inter text-2xl font-bold text-on-surface tracking-tight">ChronoPlan</h2>
                </div>

                @RenderBody()
            </div>
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
