    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    <script>
        const currentUserId = "@Context.Session.GetString("UserId")";
        const notificationButton = document.getElementById("notificationButton");
        const notificationDropdown = document.getElementById("notificationDropdown");
        const notificationList = document.getElementById("notificationList");
        const notificationBadge = document.getElementById("notificationBadge");

        notificationButton?.addEventListener("click", async () => {
            if (!notificationDropdown) return;
            notificationDropdown.classList.toggle("hidden");

            if (!notificationDropdown.classList.contains("hidden")) {
                await refreshNotifications();
            }
        });

        document.addEventListener("click", (event) => {
            if (!notificationDropdown || !notificationButton) return;
            if (notificationDropdown.contains(event.target) || notificationButton.contains(event.target)) {
                return;
            }
            notificationDropdown.classList.add("hidden");
        });

        async function refreshNotifications() {
            if (!notificationList) return;
            const response = await fetch("/Notification/List");
            if (!response.ok) return;
            const data = await response.json();

            notificationList.innerHTML = "";

            if (!data.length) {
                const empty = document.createElement("div");
                empty.className = "px-4 py-4 text-sm text-on-surface-variant";
                empty.textContent = "No notifications.";
                notificationList.appendChild(empty);
                return;
            }

            data.forEach(item => {
                const button = document.createElement("button");
                button.type = "button";
                button.dataset.id = item.notificationId;
                button.className = `notification-item w-full text-left px-4 py-3 border-b border-[#e5e7eb] hover:bg-[#f8fafc] transition-colors ${item.isRead ? "text-on-surface-variant" : "text-on-surface"}`;
                button.innerHTML = `
                    <div class="text-sm font-semibold">${item.title}</div>
                    <div class="text-xs opacity-80">${item.message}</div>
                    <div class="text-[10px] opacity-60 mt-1">${new Date(item.createdAt).toLocaleString()}</div>
                `;
                button.addEventListener("click", () => markNotificationRead(button));
                notificationList.appendChild(button);
            });
        }

        async function markNotificationRead(element) {
            const id = element.dataset.id;
            if (!id) return;

            const formData = new FormData();
            formData.append("notificationId", id);

            const response = await fetch("/Notification/MarkRead", {
                method: "POST",
                headers: {
                    "RequestVerificationToken": document.querySelector("input[name='__RequestVerificationToken']")?.value || ""
                },
                body: formData
            });

            if (!response.ok) return;
            const result = await response.json();
            element.classList.add("text-on-surface-variant");
            updateBadge(result.unreadCount);
        }

        function updateBadge(count) {
            if (!notificationBadge) return;
            if (count > 0) {
                notificationBadge.textContent = count;
                notificationBadge.classList.remove("hidden");
            } else {
                notificationBadge.classList.add("hidden");
            }
        }

        document.querySelectorAll(".calendar-alert").forEach(alertElement => {
            setTimeout(() => alertElement.remove(), 10000);
        });

        function showSuccess(value) {
            if (!value) return "";
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return value;

            return date.toLocaleString("en-US", {
                month: "2-digit",
                day: "2-digit",
                year: "numeric",
                hour: "numeric",
                minute: "2-digit",
                hour12: true
            });
        }

        let currentAppointmentDetails = null;

        function getDateTime(value) {
            if (!value) return "";

            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return "";

            const pad = number => String(number).padStart(2, "0");

            return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}T${pad(date.getHours())}:${pad(date.getMinutes())}`;
        }

        async function openAppointmentDetails(appointmentId) {
            const modal = document.getElementById("appointmentDetailsModal");
            if (!modal || !appointmentId) return;

            const response = await fetch(`/Calendar/AppointmentDetails/${encodeURIComponent(appointmentId)}`);
            if (!response.ok) return;

            const details = await response.json();
            currentAppointmentDetails = details;

            document.getElementById("appointmentDetailsTitle").textContent = details.title || "Appointment";
            document.getElementById("appointmentDetailsStart").textContent = showSuccess(details.startTime);
            document.getElementById("appointmentDetailsEnd").textContent = showSuccess(details.endTime);
            document.getElementById("appointmentDetailsLocation").textContent = details.location || "No location";
            document.getElementById("appointmentDetailsEditButton")?.classList.toggle("hidden", !details.canEdit);
            document.getElementById("appointmentDetailsDeleteButton")?.classList.toggle("hidden", !details.canEdit);

            const badge = document.getElementById("appointmentDetailsGroupBadge");
            const section = document.getElementById("appointmentDetailsParticipantsSection");
            const participantsContainer = document.getElementById("appointmentDetailsParticipants");

            badge?.classList.toggle("hidden", !details.isGroupMeeting);
            section?.classList.toggle("hidden", !details.isGroupMeeting);

            if (participantsContainer) {
                participantsContainer.innerHTML = "";

                if (details.isGroupMeeting && details.participants?.length) {
                    details.participants.forEach(participant => {
                        const row = document.createElement("div");
                        row.className = "rounded-lg border border-outline-variant bg-surface-container-lowest px-3 py-2";

                        const name = document.createElement("div");
                        name.className = "text-sm font-semibold text-on-surface";
                        name.textContent = participant.name;

                        const meta = document.createElement("div");
                        meta.className = "text-xs text-on-surface-variant mt-0.5";
                        meta.textContent = `${participant.email} - Joined ${showSuccess(participant.joinedAt)}`;

                        row.appendChild(name);
                        row.appendChild(meta);
                        participantsContainer.appendChild(row);
                    });
                } else if (details.isGroupMeeting) {
                    const empty = document.createElement("div");
                    empty.className = "text-sm text-on-surface-variant";
                    empty.textContent = "No participants.";
                    participantsContainer.appendChild(empty);
                }
            }

            hideAppointmentEditForm();
            modal.classList.remove("hidden");
            modal.classList.add("flex");
        }

        function closeAppointmentDetails() {
            const modal = document.getElementById("appointmentDetailsModal");
            if (!modal) return;

            modal.classList.add("hidden");
            modal.classList.remove("flex");
            currentAppointmentDetails = null;
            hideAppointmentEditForm();
        }

        function showAppointmentEditForm() {
            if (!currentAppointmentDetails?.canEdit) return;

            document.getElementById("appointmentDetailsView")?.classList.add("hidden");
            document.getElementById("appointmentEditForm")?.classList.remove("hidden");

            document.getElementById("editAppointmentId").value = currentAppointmentDetails.appointmentId || "";
            document.getElementById("editTitle").value = currentAppointmentDetails.title || "";
            document.getElementById("editLocation").value = currentAppointmentDetails.location || "";
            document.getElementById("editStartTime").value = getDateTime(currentAppointmentDetails.startTime);
            document.getElementById("editEndTime").value = getDateTime(currentAppointmentDetails.endTime);

            const isGroupMeeting = Boolean(currentAppointmentDetails.isGroupMeeting);
            document.getElementById("editIsGroupMeeting").checked = isGroupMeeting;
            document.getElementById("editIsGroupMeetingHidden").value = isGroupMeeting ? "true" : "false";
            document.getElementById("editReminderType").value = currentAppointmentDetails.reminderType || "Popup";

            const selectedReminders = new Set((currentAppointmentDetails.reminderMinutesBefore || []).map(Number));
            document.querySelectorAll("[data-edit-reminder]").forEach(input => {
                input.checked = selectedReminders.has(Number(input.value));
            });
        }

        function hideAppointmentEditForm() {
            document.getElementById("appointmentDetailsView")?.classList.remove("hidden");
            document.getElementById("appointmentEditForm")?.classList.add("hidden");
        }

        function deleteCurrentAppointment() {
            if (!currentAppointmentDetails?.canEdit || !currentAppointmentDetails?.appointmentId) return;

            const confirmed = window.confirm("Delete this appointment? This action cannot be undone.");
            if (!confirmed) return;

            const form = document.createElement("form");
            form.method = "post";
            form.action = "/Calendar/DeleteAppointment";

            const token = document.querySelector("input[name='__RequestVerificationToken']")?.value;
            if (token) {
                const tokenInput = document.createElement("input");
                tokenInput.type = "hidden";
                tokenInput.name = "__RequestVerificationToken";
                tokenInput.value = token;
                form.appendChild(tokenInput);
            }

            const appointmentInput = document.createElement("input");
            appointmentInput.type = "hidden";
            appointmentInput.name = "appointmentId";
            appointmentInput.value = currentAppointmentDetails.appointmentId;
            form.appendChild(appointmentInput);

            const weekStartInput = document.createElement("input");
            weekStartInput.type = "hidden";
            weekStartInput.name = "weekStart";
            weekStartInput.value = "@Model.WeekStart.ToString("yyyy-MM-dd")";
            form.appendChild(weekStartInput);

            document.body.appendChild(form);
            form.submit();
        }

        function clickAddAppointment() {
            const modal = document.getElementById("createModal");
            if (!modal) return;

            modal.classList.remove("hidden");
            modal.classList.add("flex");
        }

        function closeCreateModal() {
            const modal = document.getElementById("createModal");
            if (!modal) return;

            modal.classList.add("hidden");
            modal.classList.remove("flex");
        }

        function displayAddAppointmentWindow(cell) {
            const start = cell.dataset.start;
            const end = cell.dataset.end;

            const startInput = document.getElementById("modalStartTime");
            const endInput = document.getElementById("modalEndTime");

            if (startInput && start) {
                startInput.value = start;
            }

            if (endInput && end) {
                endInput.value = end;
            }

            clickAddAppointment();
        }
    
        function updateCalendar() {
            const line = document.getElementById("currentTimeLine");
            if (!line) return;

            const now = new Date();

            const calendarStartHour = 1;
            const calendarEndHour = 24;
            const pixelsPerHour = 56;
            const topMetaRowHeight = 36;

            const minutesFromStart =
                ((now.getHours() - calendarStartHour) * 60) + now.getMinutes();

            const totalVisibleMinutes = (calendarEndHour - calendarStartHour) * 60;

            if (minutesFromStart < 0 || minutesFromStart > totalVisibleMinutes) {
                line.style.display = "none";
                return;
            }

            const topPx = minutesFromStart * pixelsPerHour / 60;

            line.style.display = "flex";
            line.style.top = `${topMetaRowHeight + topPx}px`;
        }

        updateCalendar();
        setInterval(updateCalendar, 60000);

        if (currentUserId) {
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/notificationHub")
                .withAutomaticReconnect()
                .build();

            connection.on("NotificationReceived", payload => {
                updateBadge(payload.unreadCount);
                const toast = document.createElement("div");
                toast.className = "fixed bottom-6 right-6 bg-white border border-[#d1d5db] text-[#111827] px-4 py-3 rounded-lg shadow-lg z-50";
                toast.innerHTML = `<div class="font-semibold">${payload.title}</div><div class="text-sm opacity-80">${payload.message}</div>`;
                document.body.appendChild(toast);
                setTimeout(() => toast.remove(), 5000);

                if (notificationList && !notificationDropdown?.classList.contains("hidden")) {
                    refreshNotifications();
                }
            });

            connection.start().then(() => connection.invoke("JoinUserGroup", currentUserId));
        }
    
        function toggleSidebar() {
            const sidebar = document.getElementById("sidebar");
            const main = document.getElementById("calendarMain");

            if (!sidebar || !main) return;

            const isCollapsed = sidebar.classList.toggle("-translate-x-full");

            if (isCollapsed) {
                main.classList.remove("ml-64");
                main.classList.add("ml-0");
                localStorage.setItem("chronoSidebarCollapsed", "true");
            } else {
                main.classList.remove("ml-0");
                main.classList.add("ml-64");
                localStorage.setItem("chronoSidebarCollapsed", "false");
            }
        }

        function applySidebarState() {
            const sidebar = document.getElementById("sidebar");
            const main = document.getElementById("calendarMain");

            if (!sidebar || !main) return;

            const isCollapsed = localStorage.getItem("chronoSidebarCollapsed") === "true";

            if (isCollapsed) {
                sidebar.classList.add("-translate-x-full");
                main.classList.remove("ml-64");
                main.classList.add("ml-0");
            } else {
                sidebar.classList.remove("-translate-x-full");
                main.classList.remove("ml-0");
                main.classList.add("ml-64");
            }
        }

        document.addEventListener("DOMContentLoaded", applySidebarState);
    
        let isDraggingSlot = false;
        let dragStartCell = null;
        let dragEndCell = null;

        function clearSlotSelection() {
            document.querySelectorAll(".calendar-cell.is-selecting")
                .forEach(cell => cell.classList.remove("is-selecting"));
        }

        function startSlotDrag(event, cell) {
            if (event.button !== 0) return;

            event.preventDefault();
            event.stopPropagation();

            isDraggingSlot = true;
            dragStartCell = cell;
            dragEndCell = cell;

            document.body.classList.add("dragging-calendar-slot");

            clearSlotSelection();
            cell.classList.add("is-selecting");
        }

        function extendSlotDrag(cell) {
            if (!isDraggingSlot || !dragStartCell) return;

            const startDay = dragStartCell.dataset.dayIndex;
            const currentDay = cell.dataset.dayIndex;

            // Chỉ cho kéo trong cùng một ngày/cột
            if (startDay !== currentDay) return;

            dragEndCell = cell;
            paintSlotSelection();
        }

        function paintSlotSelection() {
            if (!dragStartCell || !dragEndCell) return;

            clearSlotSelection();

            const dayIndex = dragStartCell.dataset.dayIndex;
            const startSlot = parseInt(dragStartCell.dataset.slotIndex);
            const endSlot = parseInt(dragEndCell.dataset.slotIndex);

            const minSlot = Math.min(startSlot, endSlot);
            const maxSlot = Math.max(startSlot, endSlot);

            document
                .querySelectorAll(`.calendar-cell[data-day-index="${dayIndex}"]`)
                .forEach(cell => {
                    const slot = parseInt(cell.dataset.slotIndex);

                    if (slot >= minSlot && slot <= maxSlot) {
                        cell.classList.add("is-selecting");
                    }
                });
        }

        document.addEventListener("mouseup", function () {
            if (!isDraggingSlot || !dragStartCell || !dragEndCell) return;

            const startSlot = parseInt(dragStartCell.dataset.slotIndex);
            const endSlot = parseInt(dragEndCell.dataset.slotIndex);

            let startCell = dragStartCell;
            let endCell = dragEndCell;

            if (endSlot < startSlot) {
                startCell = dragEndCell;
                endCell = dragStartCell;
            }

            const startInput = document.getElementById("modalStartTime");
            const endInput = document.getElementById("modalEndTime");

            if (startInput && startCell.dataset.start) {
                startInput.value = startCell.dataset.start;
            }

            if (endInput && endCell.dataset.end) {
                endInput.value = endCell.dataset.end;
            }

            isDraggingSlot = false;
            document.body.classList.remove("dragging-calendar-slot");

            clickAddAppointment();

            setTimeout(() => {
                clearSlotSelection();
                dragStartCell = null;
                dragEndCell = null;
            }, 150);
        });

        document.addEventListener("keydown", function (event) {
            if (event.key !== "Escape") return;

            isDraggingSlot = false;
            dragStartCell = null;
            dragEndCell = null;

            document.body.classList.remove("dragging-calendar-slot");
            clearSlotSelection();
        });
    </script>
</body>
</html>










