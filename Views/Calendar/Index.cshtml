@model CalendarPageViewModel

@{
    Layout = null;
    ViewBag.Title = "Calendar Dashboard";

    var miniCalendarStart = new DateTime(Model.WeekStart.Year, Model.WeekStart.Month, 1);
    var miniStartOffset = (int)miniCalendarStart.DayOfWeek;
    var miniGridStart = miniCalendarStart.AddDays(-miniStartOffset);
    var todayWeekStart = DateTime.Today.AddDays(-(((int)DateTime.Today.DayOfWeek + 6) % 7));

    var currentMode = Context.Request.Query["viewMode"].ToString();
    currentMode = string.IsNullOrWhiteSpace(currentMode) ? "week" : currentMode.ToLowerInvariant();

    if (currentMode != "day" && currentMode != "week" && currentMode != "month")
    {
        currentMode = "week";
    }

    var isDayView = currentMode == "day";
    var isWeekView = currentMode == "week";
    var isMonthView = currentMode == "month";

    var selectedDateValue = Context.Request.Query["selectedDate"].ToString();
    DateTime selectedDate;

    if (!DateTime.TryParse(selectedDateValue, out selectedDate))
    {
        selectedDate = DateTime.Today;
    }

    selectedDate = selectedDate.Date;

    DateTime GetMonday(DateTime date)
    {
        return date.Date.AddDays(-(((int)date.DayOfWeek + 6) % 7));
    }

    var selectedWeekStart = GetMonday(selectedDate);

    var previousSelectedDate = isDayView
        ? selectedDate.AddDays(-1)
        : isMonthView
            ? selectedDate.AddMonths(-1)
            : selectedDate.AddDays(-7);

    var nextSelectedDate = isDayView
        ? selectedDate.AddDays(1)
        : isMonthView
            ? selectedDate.AddMonths(1)
            : selectedDate.AddDays(7);

    var previousWeekRoute = GetMonday(previousSelectedDate);
    var nextWeekRoute = GetMonday(nextSelectedDate);

    var timelineDays = isDayView
        ? new List<DateTime> { selectedDate }
        : Model.Days;

    var monthStart = new DateTime(selectedDate.Year, selectedDate.Month, 1);
    var monthGridStart = GetMonday(monthStart);
    var monthCells = Enumerable.Range(0, 42)
        .Select(i => monthGridStart.AddDays(i))
        .ToList();

    var headerTitle = isDayView
        ? selectedDate.ToString("dddd, dd MMMM yyyy")
        : isMonthView
            ? selectedDate.ToString("MMMM yyyy")
            : $"{Model.WeekStart:dd MMM} - {Model.WeekStart.AddDays(6):dd MMM yyyy}";
}

<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f5f7fb;
        }

        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #f8fafc;
        }

        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

        .calendar-cell:hover {
            background-color: rgba(26, 115, 232, 0.08);
        }
    
        .calendar-cell.is-selecting {
            background-color: rgba(26, 115, 232, 0.28);
            box-shadow: inset 3px 0 0 #1A73E8;
        }

        body.dragging-calendar-slot {
            cursor: crosshair;
            user-select: none;
        }
    
        .calendar-quarter-cell {
            height: 14px;
        }

        .calendar-quarter-cell:hover {
            background-color: rgba(26, 115, 232, 0.08);
        }

        .calendar-quarter-cell.is-selecting {
            background-color: rgba(26, 115, 232, 0.28);
            box-shadow: inset 3px 0 0 #1A73E8;
        }

        body.dragging-calendar-slot {
            cursor: crosshair;
            user-select: none;
        }
    </style>

    <script id="tailwind-config">
        tailwind.config = {
            theme: {
                extend: {
                    "colors": {
                        "surface-tint": "#2563eb",
                        "primary-container": "#2563eb",
                        "surface-container-low": "#f8fafc",
                        "on-primary-fixed": "#001a41",
                        "tertiary-container": "#e5e7eb",
                        "outline": "#94a3b8",
                        "on-secondary-fixed-variant": "#41474d",
                        "on-background": "#111827",
                        "inverse-on-surface": "#313030",
                        "primary-fixed": "#d8e2ff",
                        "secondary-fixed-dim": "#c1c7cd",
                        "on-tertiary-fixed": "#1a1c1e",
                        "tertiary-fixed-dim": "#c7c6ca",
                        "secondary-container": "#e5e7eb",
                        "on-surface-variant": "#6b7280",
                        "tertiary-fixed": "#e3e2e6",
                        "inverse-primary": "#005bc0",
                        "error": "#dc2626",
                        "surface-container-lowest": "#ffffff",
                        "surface-container-highest": "#e5e7eb",
                        "on-tertiary-fixed-variant": "#46474a",
                        "surface-container": "#f8fafc",
                        "outline-variant": "#e5e7eb",
                        "surface-dim": "#f5f7fb",
                        "secondary-fixed": "#dde3e9",
                        "on-error-container": "#991b1b",
                        "on-secondary-container": "#374151",
                        "surface-bright": "#ffffff",
                        "on-tertiary-container": "#111827",
                        "on-secondary": "#2b3136",
                        "on-primary-container": "#ffffff",
                        "surface-container-high": "#ffffff",
                        "on-primary-fixed-variant": "#004493",
                        "on-primary": "#002e68",
                        "on-surface": "#111827",
                        "on-error": "#690005",
                        "error-container": "#fee2e2",
                        "background": "#f5f7fb",
                        "on-tertiary": "#2f3033",
                        "inverse-surface": "#111827",
                        "tertiary": "#c7c6ca",
                        "primary": "#2563eb",
                        "surface": "#ffffff",
                        "primary-fixed-dim": "#bfdbfe",
                        "on-secondary-fixed": "#161c21",
                        "secondary": "#c1c7cd",
                        "surface-variant": "#f3f4f6"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "gutter": "1rem",
                        "margin-page": "1.5rem",
                        "grid-cell-height": "48px",
                        "padding-compact": "0.5rem",
                        "sidebar-width": "256px",
                        "padding-standard": "1rem"
                    },
                    "fontFamily": {
                        "headline-sm": ["Inter"],
                        "display-date": ["Inter"],
                        "body-sm": ["Inter"],
                        "body-md": ["Inter"],
                        "label-caps": ["Inter"],
                        "grid-number": ["Inter"]
                    },
                    "fontSize": {
                        "headline-sm": ["16px", { "lineHeight": "24px", "fontWeight": "500" }],
                        "display-date": ["22px", { "lineHeight": "28px", "fontWeight": "500" }],
                        "body-sm": ["12px", { "lineHeight": "16px", "fontWeight": "400" }],
                        "body-md": ["14px", { "lineHeight": "20px", "fontWeight": "400" }],
                        "label-caps": ["11px", { "lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "600" }],
                        "grid-number": ["24px", { "lineHeight": "32px", "fontWeight": "300" }]
                    }
                }
            }
        }
    </script>
</head>

<body class="bg-surface text-on-surface flex flex-col h-screen overflow-hidden">

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="calendar-alert fixed top-20 right-20 z-[999] px-4 py-3 rounded-lg bg-green-50 text-green-800 border border-green-200 shadow-lg flex items-center gap-3">
            <span>@Model.SuccessMessage</span>
            <button type="button" class="text-green-700 hover:text-green-900" onclick="this.closest('.calendar-alert')?.remove()">
                <span class="material-symbols-outlined text-base">close</span>
            </button>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="calendar-alert fixed top-20 right-20 z-[999] px-4 py-3 rounded-lg bg-red-50 text-red-800 border border-red-200 shadow-lg flex items-center gap-3">
            <span>@Model.ErrorMessage</span>
            <button type="button" class="text-red-700 hover:text-red-900" onclick="this.closest('.calendar-alert')?.remove()">
                <span class="material-symbols-outlined text-base">close</span>
            </button>
        </div>
    }

    <header class="flex justify-between items-center px-4 h-16 w-full bg-white border-b border-[#e5e7eb] font-inter text-sm antialiased sticky top-0 z-50 shadow-sm">
        <div class="flex items-center gap-4">
            <button id="sidebarToggle" onclick="toggleSidebar()" class="p-2 hover:bg-[#f3f4f6] transition-colors rounded-full cursor-pointer text-[#374151]">
                <span class="material-symbols-outlined">menu</span>
            </button>

            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-[#1A73E8] text-2xl">calendar_today</span>
                <span class="text-xl font-bold text-[#111827] tracking-tight">Chronos</span>
            </div>

            <div class="flex items-center gap-1 ml-6">
                <a asp-controller="Calendar"
                   asp-action="Index"
                   asp-route-weekStart="@todayWeekStart.ToString("yyyy-MM-dd")"
                   asp-route-selectedDate="@DateTime.Today.ToString("yyyy-MM-dd")"
                   asp-route-viewMode="@currentMode"
                   class="px-4 py-2 border border-[#d1d5db] text-[#1f2937] rounded-lg font-medium hover:bg-[#f3f4f6] transition-colors">
                    Today
                </a>

                <div class="flex ml-2">
                    <a asp-controller="Calendar"
                       asp-action="Index"
                       asp-route-weekStart="@previousWeekRoute.ToString("yyyy-MM-dd")"
                       asp-route-selectedDate="@previousSelectedDate.ToString("yyyy-MM-dd")"
                       asp-route-viewMode="@currentMode"
                       class="p-2 hover:bg-[#f3f4f6] text-[#374151] transition-colors rounded-full">
                        <span class="material-symbols-outlined">chevron_left</span>
                    </a>

                    <a asp-controller="Calendar"
                       asp-action="Index"
                       asp-route-weekStart="@nextWeekRoute.ToString("yyyy-MM-dd")"
                       asp-route-selectedDate="@nextSelectedDate.ToString("yyyy-MM-dd")"
                       asp-route-viewMode="@currentMode"
                       class="p-2 hover:bg-[#f3f4f6] text-[#374151] transition-colors rounded-full">
                        <span class="material-symbols-outlined">chevron_right</span>
                    </a>
                </div>

                <h1 class="text-display-date font-display-date ml-4 text-[#111827]">
                    @headerTitle
                </h1>
            </div>
        </div>

        <div class="flex items-center gap-2">
            <div class="relative">
                <button id="notificationButton"
                        type="button"
                        class="p-2 hover:bg-[#f3f4f6] text-[#374151] transition-colors rounded-full relative">
                    <span class="material-symbols-outlined">notifications</span>
                    <span id="notificationBadge"
                          class="absolute -top-1 -right-1 text-[10px] bg-red-500 text-white rounded-full px-1.5 py-0.5 @(Model.UnreadNotificationCount > 0 ? "" : "hidden")">
                        @Model.UnreadNotificationCount
                    </span>
                </button>

                <div id="notificationDropdown"
                     class="hidden absolute right-0 mt-2 w-80 bg-white border border-[#e5e7eb] rounded-lg shadow-xl overflow-hidden z-50">
                    <div class="px-4 py-2 border-b border-[#e5e7eb] text-sm font-semibold text-[#111827]">
                        Notifications
                    </div>
                    <div id="notificationList" class="max-h-72 overflow-y-auto">
                        @if (Model.Notifications.Any())
                        {
                            foreach (var notification in Model.Notifications)
                            {
                                <button type="button"
                                        data-id="@notification.NotificationId"
                                        class="notification-item w-full text-left px-4 py-3 border-b border-[#e5e7eb] hover:bg-[#f8fafc] transition-colors @(notification.IsRead ? "text-on-surface-variant" : "text-on-surface")">
                                    <div class="text-sm font-semibold">@notification.Title</div>
                                    <div class="text-xs opacity-80">@notification.Message</div>
                                    <div class="text-[10px] opacity-60 mt-1">@notification.CreatedAt.ToLocalTime().ToString("g")</div>
                                </button>
                            }
                        }
                        else
                        {
                            <div class="px-4 py-4 text-sm text-on-surface-variant">
                                No notifications.
                            </div>
                        }
                    </div>
                </div>
            </div>

            <form asp-controller="Auth" asp-action="Logout" method="post" class="ml-2">
                @Html.AntiForgeryToken()
                <button type="submit" class="px-3 py-2 rounded-lg border border-[#d1d5db] bg-white hover:bg-[#f3f4f6] text-[#1f2937]">
                    Logout
                </button>
            </form>

            <div class="ml-2 w-8 h-8 rounded-full overflow-hidden border border-[#d1d5db] bg-primary-container flex items-center justify-center">
                <span class="text-white text-sm font-bold">
                    @(Context.Session.GetString("UserName")?.Substring(0, 1).ToUpper() ?? "U")
                </span>
            </div>
        </div>
    </header>

    <div class="flex flex-1 overflow-hidden">
        <aside id="sidebar" class="fixed left-0 top-16 h-[calc(100vh-64px)] w-64 transition-transform duration-300 bg-white border-r border-[#e5e7eb] flex flex-col py-4 gap-2 font-inter text-sm font-medium z-40">
            <div class="px-4 mb-6">
                <button onclick="clickAddAppointment()"
                        class="flex items-center gap-3 bg-primary-container text-white px-6 py-3.5 rounded-full shadow-lg hover:bg-blue-700 transition-all font-bold active:opacity-80">
                    <span class="material-symbols-outlined font-bold">add</span>
                    <span>Create</span>
                </button>
            </div>

            <div class="px-4 mb-8">
                <div class="flex justify-between items-center mb-4 px-2">
                    <span class="font-bold text-[#111827]">@Model.WeekStart.ToString("MMMM yyyy")</span>

                    <div class="flex gap-1">
                        <a asp-controller="Calendar"
                           asp-action="Index"
                           asp-route-weekStart="@Model.PreviousWeekStart.ToString("yyyy-MM-dd")"
                           class="material-symbols-outlined text-sm text-[#374151] cursor-pointer hover:bg-[#f3f4f6] rounded p-1">chevron_left</a>

                        <a asp-controller="Calendar"
                           asp-action="Index"
                           asp-route-weekStart="@Model.NextWeekStart.ToString("yyyy-MM-dd")"
                           class="material-symbols-outlined text-sm text-[#374151] cursor-pointer hover:bg-[#f3f4f6] rounded p-1">chevron_right</a>
                    </div>
                </div>

                <div class="grid grid-cols-7 text-center gap-y-2">
                    <div class="text-[10px] text-[#6b7280]">S</div>
                    <div class="text-[10px] text-[#6b7280]">M</div>
                    <div class="text-[10px] text-[#6b7280]">T</div>
                    <div class="text-[10px] text-[#6b7280]">W</div>
                    <div class="text-[10px] text-[#6b7280]">T</div>
                    <div class="text-[10px] text-[#6b7280]">F</div>
                    <div class="text-[10px] text-[#6b7280]">S</div>

                    @for (var i = 0; i < 35; i++)
                    {
                        var miniDay = miniGridStart.AddDays(i);
                        var isCurrentMonth = miniDay.Month == Model.WeekStart.Month;
                        var isToday = miniDay.Date == DateTime.Today;
                        var miniWeekStart = miniDay.AddDays(-(((int)miniDay.DayOfWeek + 6) % 7));

                        <a asp-controller="Calendar"
                           asp-action="Index"
                           asp-route-weekStart="@miniWeekStart.ToString("yyyy-MM-dd")"
                           class="text-xs py-1 text-[#374151] @(isCurrentMonth ? "hover:bg-[#eef2ff] rounded-full cursor-pointer" : "text-gray-400") @(isToday ? "bg-primary-container text-white rounded-full" : "")">
                            @miniDay.Day
                        </a>
                    }
                </div>
            </div>

            <nav class="flex flex-col gap-1 overflow-y-auto">
                                <a asp-controller="Calendar"
                   asp-action="Index"
                   asp-route-weekStart="@selectedWeekStart.ToString("yyyy-MM-dd")"
                   asp-route-selectedDate="@selectedDate.ToString("yyyy-MM-dd")"
                   asp-route-viewMode="week"
                   class="flex items-center gap-3 px-6 py-2 transition-all duration-200 @(isWeekView ? "bg-[#dbeafe] text-[#1d4ed8] rounded-r-full border-l-4 border-[#2563eb]" : "text-[#4b5563] hover:text-[#111827] hover:bg-[#f3f4f6] rounded-lg")">
                    <span class="material-symbols-outlined">calendar_view_week</span>
                    <span>Week</span>
                </a>

                <a asp-controller="Calendar"
                   asp-action="Index"
                   asp-route-weekStart="@selectedWeekStart.ToString("yyyy-MM-dd")"
                   asp-route-selectedDate="@selectedDate.ToString("yyyy-MM-dd")"
                   asp-route-viewMode="day"
                   class="flex items-center gap-3 px-6 py-2 transition-all duration-200 @(isDayView ? "bg-[#dbeafe] text-[#1d4ed8] rounded-r-full border-l-4 border-[#2563eb]" : "text-[#4b5563] hover:text-[#111827] hover:bg-[#f3f4f6] rounded-lg")">
                    <span class="material-symbols-outlined">calendar_view_day</span>
                    <span>Day</span>
                </a>

                <a asp-controller="Calendar"
                   asp-action="Index"
                   asp-route-weekStart="@selectedWeekStart.ToString("yyyy-MM-dd")"
                   asp-route-selectedDate="@selectedDate.ToString("yyyy-MM-dd")"
                   asp-route-viewMode="month"
                   class="flex items-center gap-3 px-6 py-2 transition-all duration-200 @(isMonthView ? "bg-[#dbeafe] text-[#1d4ed8] rounded-r-full border-l-4 border-[#2563eb]" : "text-[#4b5563] hover:text-[#111827] hover:bg-[#f3f4f6] rounded-lg")">
                    <span class="material-symbols-outlined">calendar_view_month</span>
                    <span>Month</span>
                </a>

                <div class="mt-8 px-6">
                    <div class="flex justify-between items-center text-label-caps font-label-caps text-on-surface-variant mb-4">
                        <span>MY CALENDARS</span>
                        <span class="material-symbols-outlined text-sm">keyboard_arrow_up</span>
                    </div>

                    <div class="flex flex-col gap-3">
                        <label class="flex items-center gap-3 cursor-pointer">
                            <input checked class="w-4 h-4 rounded border-[#d1d5db] bg-white text-[#2563eb] focus:ring-0 focus:ring-offset-0" type="checkbox" />
                            <span class="text-xs text-on-surface">
                                @(Context.Session.GetString("UserName") ?? "My Calendar")
                            </span>
                        </label>

                        <label class="flex items-center gap-3 cursor-pointer">
                            <input checked class="w-4 h-4 rounded border-[#d1d5db] bg-white text-[#16a34a] focus:ring-0 focus:ring-offset-0" type="checkbox" />
                            <span class="text-xs text-on-surface">Group Meetings</span>
                        </label>

                    </div>
                </div>

            </nav>
        </aside>

                <main id="calendarMain" class="flex-1 ml-64 transition-all duration-300 overflow-y-auto bg-surface-dim relative">
            @if (isMonthView)
            {
                <div class="sticky top-0 z-30 bg-white border-b border-[#e5e7eb] grid grid-cols-7">
                    @foreach (var dayName in new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" })
                    {
                        <div class="py-3 text-center border-r border-[#e5e7eb] text-label-caps text-[#374151] uppercase">
                            @dayName
                        </div>
                    }
                </div>

                <div class="grid grid-cols-7 border-l border-t border-[#e5e7eb] bg-white">
                    @foreach (var cellDate in monthCells)
                    {
                        var isCurrentMonthCell = cellDate.Month == selectedDate.Month;
                        var isTodayCell = cellDate.Date == DateTime.Today;
                        var dayAppointments = Model.Appointments
                            .Where(x => x.StartTime.Date == cellDate.Date)
                            .OrderBy(x => x.StartTime)
                            .Take(3)
                            .ToList();

                        var defaultStart = cellDate.Date.AddHours(9);
                        var defaultEnd = defaultStart.AddHours(1);

                        <div class="min-h-[140px] border-r border-b border-[#e5e7eb] p-2 calendar-cell @(isCurrentMonthCell ? "bg-white" : "bg-[#f8fafc] text-gray-400")"
                             data-start="@defaultStart.ToString("yyyy-MM-ddTHH:mm")"
                             data-end="@defaultEnd.ToString("yyyy-MM-ddTHH:mm")"
                             onclick="displayAddAppointmentWindow(this)">
                            <div class="flex items-center justify-between mb-2">
                                @if (isTodayCell)
                                {
                                    <div class="w-8 h-8 rounded-full bg-[#dbeafe] border border-[#93c5fd] text-[#1d4ed8] flex items-center justify-center text-sm font-semibold">
                                        @cellDate.Day
                                    </div>
                                }
                                else
                                {
                                    <div class="text-sm @(isCurrentMonthCell ? "text-[#374151]" : "text-gray-400")">
                                        @cellDate.Day
                                    </div>
                                }
                            </div>

                            <div class="space-y-1">
                                @foreach (var appt in dayAppointments)
                                {
                                    <div class="px-2 py-1 rounded-lg bg-[#dbeafe] border border-[#bfdbfe] border-l-4 border-l-[#2563eb] text-[#1e3a8a] text-[11px] truncate shadow-sm"
                                         title="@appt.Title - @appt.TimeText"
                                         onclick="event.stopPropagation(); openAppointmentDetails('@appt.AppointmentId')">
                                        <div class="font-semibold truncate">@appt.Title</div>
                                        <div class="opacity-80">@appt.TimeText</div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                const int hourRowHeight = 56;
                const int topMetaRowHeight = 36;
                var isSingleDay = isDayView;

                <div class="sticky top-0 z-30 bg-white border-b border-[#e5e7eb] flex min-w-full">
                    <div class="w-16 flex-shrink-0 border-r border-[#e5e7eb]"></div>

                    <div class="flex-1 grid @(isSingleDay ? "grid-cols-1" : "grid-cols-7")">
                        @for (var i = 0; i < timelineDays.Count; i++)
                        {
                            var day = timelineDays[i];
                            var isToday = day.Date == DateTime.Today;

                            <div class="py-3 text-center border-r border-[#e5e7eb] @(isToday ? "bg-[#eff6ff]" : "")">
                                <div class="text-label-caps font-label-caps @(isToday ? "text-primary-container font-bold" : "text-on-surface-variant") uppercase">
                                    @day.ToString("ddd")
                                </div>

                                @if (isToday)
                                {
                                    <div class="text-grid-number font-grid-number bg-[#dbeafe] border border-[#93c5fd] text-[#1d4ed8] w-10 h-10 flex items-center justify-center rounded-full mx-auto">
                                        @day.Day
                                    </div>
                                }
                                else
                                {
                                    <div class="text-grid-number font-grid-number">
                                        @day.Day
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="flex min-w-full relative">
                    <div class="w-16 flex-shrink-0 flex flex-col">
                        <div class="border-r border-[#e5e7eb] relative bg-white"
                             style="height:@(topMetaRowHeight)px;">
                             <span class="absolute left-3 top-1/2 -translate-y-1/2 text-[10px] text-[#6b7280] font-medium">
                                GMT+07
                            </span>
                        </div>

                        @for (int i = 0; i < Model.TimeSlots.Count; i++)
                        {
                            <div class="relative border-r border-[#e5e7eb] bg-white"
                                 style="height:@(hourRowHeight)px;">
                                <span class="absolute right-2 top-0 -translate-y-1/2 bg-white px-1 text-[10px] leading-none text-[#6b7280]">
                                    @Model.TimeSlots[i]
                                </span>
                            </div>
                        }
                    </div>

                    <div class="flex-1 grid @(isSingleDay ? "grid-cols-1" : "grid-cols-7") divide-x divide-[#e5e7eb] bg-white">
                        @for (var dayIndex = 0; dayIndex < timelineDays.Count; dayIndex++)
                        {
                            var day = timelineDays[dayIndex];
                            var isToday = day.Date == DateTime.Today;
                            var isWeekend = !isSingleDay && dayIndex >= 5;
                            var dayAppointments = Model.Appointments
                                .Where(x => x.StartTime.Date == day.Date)
                                .OrderBy(x => x.StartTime)
                                .ToList();

                            <div class="relative @(isToday ? "bg-[#eff6ff]" : isWeekend ? "bg-[#f8fafc]" : "bg-white")">
                                <div class="border-b border-[#e5e7eb]"
                                     style="height:@(topMetaRowHeight)px;">
                                </div>

                                @for (int slotIndex = 0; slotIndex < Model.TimeSlots.Count; slotIndex++)
                                {
                                    var slotHour = 1 + slotIndex;
                                    var hourStart = day.Date.AddHours(slotHour);

                                    <div class="relative border-b border-[#e5e7eb]"
                                         style="height:@(hourRowHeight)px;">
                                        @for (int quarterIndex = 0; quarterIndex < 4; quarterIndex++)
                                        {
                                            var subSlotIndex = (slotIndex * 4) + quarterIndex;
                                            var slotStart = hourStart.AddMinutes(quarterIndex * 15);
                                            var slotEnd = slotStart.AddMinutes(15);

                                            <div class="calendar-cell calendar-quarter-cell cursor-pointer select-none"
                                                 data-day-index="@dayIndex"
                                                 data-slot-index="@subSlotIndex"
                                                 data-start="@slotStart.ToString("yyyy-MM-ddTHH:mm")"
                                                 data-end="@slotEnd.ToString("yyyy-MM-ddTHH:mm")"
                                                 onmousedown="startSlotDrag(event, this)"
                                                 onmouseenter="extendSlotDrag(this)">
                                            </div>
                                        }
                                    </div>
                                }

                                @if (isToday)
                                {
                                    <div id="currentTimeLine"
                                         class="absolute left-0 right-0 h-[2px] bg-red-500 z-20 flex items-center pointer-events-none"
                                         style="top:0px;">
                                        <div class="w-3 h-3 bg-red-500 rounded-full -ml-1.5 shadow-sm"></div>
                                    </div>
                                }

                                @foreach (var item in dayAppointments)
                                {
                                    var startHour = 1;
                                    var startMinutes = ((item.StartTime.Hour - startHour) * 60) + item.StartTime.Minute;
                                    var durationMinutes = Math.Max(30, (int)(item.EndTime - item.StartTime).TotalMinutes);

                                    if (startMinutes < 0)
                                    {
                                        continue;
                                    }

                                    var topPx = topMetaRowHeight + (startMinutes * hourRowHeight / 60);
                                    var heightPx = Math.Max(32, durationMinutes * hourRowHeight / 60);

                                    <div class="absolute left-1 right-1 @(item.IsGroupMeeting ? "bg-[#dcfce7] border-[#bbf7d0] border-l-[#16a34a] text-[#14532d]" : "bg-[#dbeafe] border-[#bfdbfe] border-l-[#2563eb] text-[#1e3a8a]") border border-l-4 rounded-lg p-2 z-10 cursor-pointer hover:brightness-105 overflow-hidden shadow-sm"
                                         style="top:@(topPx)px; height:@(heightPx)px;"
                                         title="@item.Title - @item.TimeText"
                                         onclick="event.stopPropagation(); openAppointmentDetails('@item.AppointmentId')">
                                        <div class="text-[10px] opacity-90 leading-tight">
                                            @item.TimeText
                                        </div>

                                        <div class="text-xs font-bold truncate leading-tight">
                                            @item.Title
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(item.Location))
                                        {
                                            <div class="text-[10px] opacity-80 truncate">
                                                @item.Location
                                            </div>
                                        }

                                        @if (item.IsGroupMeeting)
                                        {
                                            <div class="text-[10px] opacity-80">
                                                Group Meeting
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </main>

